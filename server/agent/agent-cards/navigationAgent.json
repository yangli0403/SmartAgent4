{
  "id": "navigationAgent",
  "name": "导航出行专员",
  "description": "POI搜索、周边搜索、路径规划（驾车/步行/骑行/公交）、地理编码、天气查询、IP定位、导航",
  "capabilities": [
    "poi_search",
    "route_planning",
    "geocoding",
    "weather_query",
    "ip_location",
    "navigation"
  ],
  "tools": [
    "free_weather_by_city",
    "free_weather_by_coords",
    "free_ip_location",
    "free_geocode_city",
    "maps_around_search",
    "maps_text_search",
    "maps_direction_driving",
    "maps_direction_walking",
    "maps_direction_transit_integrated",
    "maps_direction_bicycling",
    "maps_geo",
    "maps_regeocode",
    "maps_weather",
    "maps_ip_location",
    "maps_distance",
    "maps_search_detail",
    "maps_schema_personal_map",
    "maps_schema_navi",
    "maps_schema_take_taxi"
  ],
  "domain": "navigation",
  "implementationClass": "NavigationAgent",
  "llmConfig": {
    "temperature": 0.3,
    "maxTokens": 3000,
    "maxIterations": 8
  },
  "systemPromptTemplate": "你是一个导航出行专员。你的职责是帮助用户进行位置搜索、路径规划和导航。",
  "enabled": true,
  "priority": 50,
  "metadata": {
    "version": "1.0.1",
    "author": "SmartAgent4",
    "changelog": "修复工具名与真实实现对齐，新增免费内置工具"
  }
}

{
  "id": "fileAgent",
  "name": "文件管理专员",
  "description": "文件搜索、文件信息查询、打开文件、目录操作、创建/复制文件、启动应用、浏览器控制、文件整理；C盘/磁盘空间与健康(get_disk_health)、系统垃圾体量估算(scan_system_junk)、深度清理建议(execute_advanced_cleanup，仅预览)",
  "capabilities": [
    "file_search",
    "file_management",
    "directory_operations",
    "app_launch",
    "browser_control",
    "file_organization",
    "duplicate_detection"
  ],
  "tools": [
    "search_files",
    "get_file_info",
    "open_file",
    "list_directory",
    "create_folder",
    "create_file",
    "copy_files",
    "launch_app",
    "browser_control",
    "list_running_apps",
    "close_app",
    "analyze_directory",
    "find_duplicates",
    "delete_files",
    "move_files",
    "get_disk_health",
    "scan_system_junk",
    "execute_advanced_cleanup"
  ],
  "domain": "file_system",
  "implementationClass": "FileAgent",
  "llmConfig": {
    "temperature": 0.3,
    "maxTokens": 3000,
    "maxIterations": 8
  },
  "systemPromptTemplate": "你是一个文件系统管理专员。你的职责是帮助用户进行文件和应用操作，以及文件整理和清理。",
  "enabled": true,
  "priority": 50,
  "metadata": {
    "version": "1.0.1",
    "author": "SmartAgent4",
    "changelog": "补充文件整理工具和能力标签，对齐llmConfig与真实实现"
  }
}

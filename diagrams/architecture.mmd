graph TD
    subgraph Client["前端客户端 (React + Vite)"]
        UI[用户界面]
        Chat[对话组件]
        Cockpit[驾驶舱组件]
    end

    subgraph API_Layer["API 层 (tRPC)"]
        Router[主路由 routers.ts]
        ChatRouter[对话路由]
        MemoryRouter[记忆路由]
    end

    subgraph Agent_Engine["Agent 引擎 (Supervisor 架构)"]
        Context[上下文增强 ContextEnrichNode]
        Classify[任务分类 ClassifyNode]
        Plan[任务规划 PlanNode]
        Execute[任务执行 ExecuteNode]
        Respond[回复生成 RespondNode]
        Extract[记忆提取 MemoryExtractionNode]
        Reflect[反思与进化 ReflectionNode]
    end

    subgraph Personality_System["人格系统"]
        Engine[人格引擎 PersonalityEngine]
        PromptBuilder[Prompt 构建器]
    end

    subgraph Memory_System["记忆系统"]
        WorkingMem[工作记忆 WorkingMemory]
        HybridSearch[混合检索 HybridSearch]
        Consolidation[记忆巩固 ConsolidationService]
    end

    subgraph Tool_System["工具系统 (MCP)"]
        MCPManager[MCP 管理器]
        ToolRegistry[工具注册表 ToolRegistry]
        Tools[具体工具集]
    end

    subgraph Data_Layer["数据访问层 (Drizzle ORM)"]
        DB[数据库操作 db.ts]
        Schema[数据模型 schema.ts]
    end

    subgraph Database["底层数据库"]
        PostgreSQL[(PostgreSQL 15)]
    end

    %% 数据流与依赖关系
    UI -->|用户输入| Chat
    Chat -->|tRPC 调用| ChatRouter
    ChatRouter -->|启动对话| Agent_Engine

    Context -->|获取画像| Memory_System
    Context -->|获取 Prompt| Personality_System
    Classify -->|查询效用分数| Tool_System
    Execute -->|调用工具| Tool_System
    Extract -->|异步写入| Memory_System
    Reflect -->|更新效用分数| Tool_System
    Reflect -->|更新 Prompt 补丁| Personality_System

    Memory_System -->|CRUD| Data_Layer
    Personality_System -->|读取配置| Data_Layer
    Agent_Engine -->|保存对话| Data_Layer

    Data_Layer -->|SQL 查询| PostgreSQL

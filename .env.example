# ============================================================
# SmartAgent 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# 数据库配置（必需）
DATABASE_URL=mysql://用户名:密码@主机:端口/数据库名
# 示例: DATABASE_URL=mysql://root:password@localhost:3306/smart_agent

# JWT 密钥（必需，用于认证）
JWT_SECRET=your-secret-key-here

# ============================================================
# LLM 配置（二选一）
# ============================================================

# 方式一：Manus 内置 LLM（推荐，自动从环境变量注入，无需手动配置）
# OPENAI_API_KEY=<由 Manus 平台自动注入>
# OPENAI_BASE_URL=https://api.manus.im/api/llm-proxy/v1
# 支持模型：gpt-4.1-mini, gpt-4.1-nano, gemini-2.5-flash

# 方式二：字节跳动 Volcengine ARK（回退方案）
# ARK_API_KEY=your-ark-api-key
# ARK_API_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_DEFAULT_MODEL=ep-xxxxxxxxxxxxxxxx

# ============================================================
# OAuth 配置
# ============================================================

# OAuth Server URL
OAUTH_SERVER_URL=https://your-oauth-server.com
VITE_APP_ID=your-app-id

# GitHub OAuth（可选）
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# 测试模式（跳过 OAuth，仅用于开发/测试）
# VITE_SKIP_OAUTH=true
# SKIP_AUTH=true

# ============================================================
# MCP 工具 API Keys
# ============================================================

# 高德地图 API Key（用于 NavigationAgent 导航功能）
AMAP_API_KEY=your-amap-api-key

# 网易云音乐 MCP（内嵌服务，随主服务自动启动，无需手动配置）
# NETEASE_MCP_PORT=3001              # 内嵌 MCP 服务端口（默认 3001）
# NETEASE_COOKIE=your-netease-cookie  # 可选：登录 Cookie，提供更高品质音乐和个人数据

# ============================================================
# 其他配置
# ============================================================

# 服务端口（默认 3000）
PORT=3000

# 运行环境
NODE_ENV=development

# ============================================================
# SmartAgent3 新增配置
# ============================================================

# Emotions-Express 情感表达微服务
EMOTIONS_EXPRESS_URL=http://localhost:8000
EMOTIONS_EXPRESS_ENABLED=true

# 默认人格 ID（xiaozhi / jarvis / alfred）
DEFAULT_CHARACTER_ID=xiaozhi

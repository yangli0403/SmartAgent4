# ============================================================
# SmartAgent4 环境变量配置模板（Windows 本地版）
# 复制此文件为 .env 并填入实际值
# ============================================================

# 数据库配置（必需）
# 本地 MySQL：mysql://root:password@localhost:3306/smart_agent
# Docker MySQL：mysql://root:password@127.0.0.1:3306/smart_agent
DATABASE_URL=mysql://root:password@localhost:3306/smart_agent

# JWT 密钥（必需，用于认证，可以随意设置一个复杂字符串）
JWT_SECRET=your-secret-key-change-me

# ============================================================
# LLM 配置（至少配置一种）
# ============================================================

# 方式一：OpenAI 官方 API（推荐）
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_DEFAULT_MODEL=gpt-4.1-mini

# 方式二：字节跳动 Volcengine ARK（回退方案，无需配置 OPENAI_* 即自动启用）
# ARK_API_KEY=your-ark-api-key
# ARK_API_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_DEFAULT_MODEL=ep-xxxxxxxxxxxxxxxx

# 方式三：OpenRouter（支持多种模型）
# OPENROUTER_API_KEY=your-openrouter-api-key

# 方式四：本地 Ollama（需先安装并运行 Ollama）
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_DEFAULT_MODEL=qwen2.5:14b

# ============================================================
# 认证配置
# ============================================================

# 本地开发模式（跳过 OAuth，强烈推荐本地使用时开启）
SKIP_AUTH=true
VITE_SKIP_OAUTH=true

# OAuth Server URL（本地模式下可留空）
# OAUTH_SERVER_URL=https://your-oauth-server.com
# VITE_APP_ID=your-app-id

# GitHub OAuth（可选）
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================================
# MCP 工具 API Keys
# ============================================================

# 高德地图 API Key（用于 NavigationAgent 导航功能，可选）
# AMAP_API_KEY=your-amap-api-key

# 网易云音乐 MCP（内嵌服务，随主服务自动启动）
# NETEASE_MCP_PORT=3001
# NETEASE_COOKIE=your-netease-cookie

# ============================================================
# Emotions-System 语音合成微服务
# ============================================================

# Emotions-System 地址（需先启动 Python 微服务）
EMOTIONS_SYSTEM_URL=http://localhost:8000
EMOTIONS_SYSTEM_ENABLED=true
# 兼容旧配置名（可选；若同时配置，优先使用 EMOTIONS_SYSTEM_*）
# EMOTIONS_EXPRESS_URL=http://localhost:8000
# EMOTIONS_EXPRESS_ENABLED=true

# ============================================================
# 其他配置
# ============================================================

# 服务端口（默认 3000）
PORT=3000

# 运行环境
NODE_ENV=development

# 默认人格 ID（xiaozhi / jarvis / alfred）
DEFAULT_CHARACTER_ID=xiaozhi

# MCP 本地 Server 端口（默认 3100）
MCP_PORT=3100
